#!/usr/bin/env python3
"""sessions — search and analyze past Claude Code session transcripts.

Zero-dependency (stdlib only). Operates on the JSONL transcripts under
~/.claude/projects/<slug>/<session-uuid>.jsonl.

Schema notes baked in here so they never get re-derived:
  - Each line is one JSON object. Top-level: type, uuid, parentUuid,
    timestamp (ISO8601), sessionId, cwd, gitBranch, version, isSidechain,
    isMeta, message{role, content}.
  - type is one of: user, assistant, system, summary, file-history-snapshot,
    attachment. PostToolUse hook output / harness attachments live in
    type==attachment with text at attachment.stdout/stderr (no message.role);
    `grep --role hook` opts into searching these (excluded by default).
  - message.content is EITHER a string OR a list of blocks. Block types:
    text{text}, thinking{thinking}, tool_use{id,name,input},
    tool_result{tool_use_id, content}, image{source}.
  - "Typed" user prompts live in type==user with text blocks and NO
    tool_result block; harness-injected turns are tagged isMeta or wrapped in
    <command-*>/<*-hook>/<task-notification>/<system-reminder> tags.
  - Subagent transcripts: <slug>/<session-uuid>/subagents/<agent>.jsonl
  - Large tool outputs spill to: <slug>/<session-uuid>/tool-results/*.txt
  - Files auto-delete after cleanupPeriodDays (default 30d) — archive early.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import sys
from glob import glob

ROOT = os.path.expanduser("~/.claude/projects")

NOISE_PREFIXES = (
    "<command-", "<local-command", "<task-notification", "<system-reminder",
    "<user-prompt-submit-hook", "<session-start-hook", "<post-tool-use-hook",
    "<bash-input", "<bash-stdout", "<bash-stderr",
)


# --------------------------------------------------------------------------- #
# discovery
# --------------------------------------------------------------------------- #
ARCHIVE_DEFAULT = os.path.expanduser("~/claude-archives")


def archive_root(a):
    """Resolve the archive dir to also search, or None.

    Defaults to ~/claude-archives (where the session-archiver plugin mirrors
    transcripts past the 30d cleanup). --no-archive disables it; --archive-dir
    or $SESSIONS_ARCHIVE_DIR overrides the path.
    """
    if getattr(a, "no_archive", False):
        return None
    d = (getattr(a, "archive_dir", None) or os.environ.get("SESSIONS_ARCHIVE_DIR")
         or ARCHIVE_DEFAULT)
    return d if os.path.isdir(d) else None


def _sidecar(path):
    parts = path.split(os.sep)
    return "subagents" in parts or "tool-results" in parts


def _discover(root, recursive):
    """Yield (path, slug, session_id) for top-level session transcripts.

    Handles both the live layout (<slug>/<uuid>.jsonl) and the archiver's
    deeper mirror layout (<host>/<slug>/<uuid>/<uuid>.jsonl). Subagent and
    tool-result sidecars are excluded in both.
    """
    pattern = (os.path.join(root, "**", "*.jsonl") if recursive
               else os.path.join(root, "*", "*.jsonl"))
    for path in glob(pattern, recursive=recursive):
        if _sidecar(path):
            continue
        stem = os.path.basename(path)[:-6]  # strip .jsonl
        parent = os.path.basename(os.path.dirname(path))
        # the archive nests the session file as <slug>/<uuid>/<uuid>.jsonl
        slug = (os.path.basename(os.path.dirname(os.path.dirname(path)))
                if parent == stem else parent)
        yield path, slug, stem


def session_files(days=None, project=None, archive=None):
    """Yield (path, slug, session_id, mtime) for top-level session files,
    newest first, optionally merging an archive dir (live copy wins on dup).

    Project filtering happens before stat()ing, and a vanished file (30d
    cleanup racing the scan) is skipped rather than crashing.
    """
    import time
    cutoff = (time.time() - days * 86400) if days else None
    roots = [(ROOT, False)]
    if archive:
        roots.append((archive, True))  # live first so it wins de-dup
    seen, cand = set(), []
    for root, recursive in roots:
        for path, slug, sid in _discover(root, recursive):
            if project and project.lower() not in slug.lower():
                continue
            if sid in seen:
                continue
            try:
                mtime = os.path.getmtime(path)
            except OSError:  # file vanished between glob and stat
                continue
            seen.add(sid)
            if cutoff and mtime < cutoff:
                continue
            cand.append((path, slug, sid, mtime))
    yield from sorted(cand, key=lambda r: r[3], reverse=True)


def find_session(prefix, archive=None):
    """Resolve a session-id prefix to a path (live first, then archive)."""
    hits = glob(os.path.join(ROOT, "*", prefix + "*.jsonl"))
    if not hits:
        hits = glob(os.path.join(ROOT, "**", prefix + "*.jsonl"), recursive=True)
    if not hits and archive:
        hits = [p for p in glob(os.path.join(archive, "**", prefix + "*.jsonl"),
                                recursive=True) if not _sidecar(p)]
    if not hits:
        return None
    if len(hits) > 1:
        print(f"warning: '{prefix}' matches {len(hits)} sessions; showing "
              f"{os.path.basename(hits[0])[:-6]} — narrow the prefix to pick another.",
              file=sys.stderr)
    return hits[0]


def compile_re(pattern):
    """Compile a user-supplied regex, exiting cleanly on a bad pattern."""
    try:
        return re.compile(pattern, re.I)
    except re.error as e:
        sys.exit(f"invalid regex {pattern!r}: {e}")


def short_slug(slug):
    # project dirs look like -Users-<name>-… (macOS) or -home-<name>-… (Linux devcontainer)
    s = re.sub(r"^-(Users|home)-[^-]+-", "", slug)
    return s or "home"


def short_ts(ts):
    return ts[:16].replace("T", " ") if ts else "?"


# --------------------------------------------------------------------------- #
# content decoding (handles string-or-array, the #1 re-derived gotcha)
# --------------------------------------------------------------------------- #
def blocks(msg):
    c = msg.get("content")
    if isinstance(c, str):
        return [{"type": "text", "text": c}]
    if isinstance(c, list):
        return [b for b in c if isinstance(b, dict)]
    return []


def text_of(msg):
    """Concatenate plain text blocks (ignores tool_use/thinking/tool_result)."""
    return "\n".join(b.get("text", "") for b in blocks(msg) if b.get("type") == "text").strip()


def is_typed_prompt(rec):
    """True if rec is a genuine user-typed prompt (not tool result / injected)."""
    if rec.get("type") != "user" or rec.get("isMeta"):
        return False
    bs = blocks(rec.get("message", {}))
    if any(b.get("type") == "tool_result" for b in bs):
        return False
    txt = text_of(rec.get("message", {}))
    if not txt:
        return False
    return not txt.startswith(NOISE_PREFIXES)


def iter_records(path):
    with open(path, encoding="utf-8", errors="replace") as fh:
        for raw in fh:
            raw = raw.strip()
            if not raw:
                continue
            try:
                yield raw, json.loads(raw)
            except json.JSONDecodeError:
                continue


# --------------------------------------------------------------------------- #
# commands
# --------------------------------------------------------------------------- #
def cmd_ls(a):
    rows = []
    for path, slug, sid, _ in session_files(a.days, a.project, archive_root(a)):
        first, count, last_ts = None, 0, None
        for _, rec in iter_records(path):
            if rec.get("type") in ("user", "assistant"):
                count += 1
                last_ts = rec.get("timestamp") or last_ts
            if first is None and is_typed_prompt(rec):
                first = text_of(rec["message"])
        rows.append((short_ts(last_ts), short_slug(slug), sid[:8], count,
                     (first or "—").replace("\n", " ")[:80]))
        if a.limit and len(rows) >= a.limit:
            break
    if a.json:
        print(json.dumps([dict(zip(("date", "project", "id", "msgs", "first"), r))
                          for r in rows], indent=2))
        return
    for date, proj, sid, count, first in rows:
        print(f"{date}  {sid}  {proj:<18.18}  {count:>4} msg  {first}")


def cmd_prompts(a):
    pat = compile_re(a.grep) if a.grep else None
    for path, slug, sid, _ in session_files(a.days, a.project, archive_root(a)):
        if a.session and not sid.startswith(a.session):
            continue
        out = []
        for _, rec in iter_records(path):
            if is_typed_prompt(rec):
                t = text_of(rec["message"])
                if pat and not pat.search(t):
                    continue
                out.append((short_ts(rec.get("timestamp")), t.replace("\n", " ")))
        if out:
            print(f"\n=== {short_slug(slug)}  {sid[:8]} ===")
            for ts, t in out:
                print(f"  [{ts}] {t[:240]}")


def cmd_grep(a):
    pat = compile_re(a.pattern)
    # The raw-line pre-filter is a speed hack and is only valid when JSON
    # escaping can't alter the pattern's literals: quotes -> \", backslashes,
    # and (under ensure_ascii) non-ASCII -> \uXXXX. Otherwise fall back to
    # decoded-text search so genuine matches aren't silently dropped.
    raw_safe = a.pattern.isascii() and '"' not in a.pattern and "\\" not in a.pattern
    # "hook" is its own opt-in mode over type==attachment records (PostToolUse
    # hook output / harness attachments); it is NOT folded into "both", so the
    # default user+assistant search stays free of tool noise.
    hook_mode = a.role == "hook"
    roles = {"hook"} if hook_mode else ({"user", "assistant"} if a.role == "both" else {a.role})
    n = 0
    for path, slug, sid, _ in session_files(a.days, a.project, archive_root(a)):
        printed_header = False
        seen = set()
        for raw, rec in iter_records(path):
            role = "hook" if rec.get("type") == "attachment" else rec.get("type")
            if role not in roles:
                continue
            if raw_safe and not pat.search(raw):  # escape-safe fast pre-filter
                continue
            if hook_mode:
                att = rec.get("attachment") or {}
                txt = "\n".join(att.get(k, "") for k in ("stdout", "stderr")
                                if isinstance(att.get(k), str)).strip()
            else:
                txt = text_of(rec.get("message", {}))
            m = pat.search(txt)
            if not m:
                continue
            if txt in seen:  # same message can recur across JSONL lines
                continue
            seen.add(txt)
            if not printed_header:
                print(f"\n=== {short_slug(slug)}  {sid[:8]} ===")
                printed_header = True
            s, e = max(0, m.start() - 50), m.end() + 80
            snip = txt[s:e].replace("\n", " ")
            print(f"  [{short_ts(rec.get('timestamp'))}] {role[:4]}: …{snip}…")
            n += 1
    print(f"\n{n} match(es).", file=sys.stderr)


def cmd_show(a):
    path = find_session(a.session, archive_root(a))
    if not path:
        sys.exit(f"no session matching '{a.session}'")
    print(f"# {path}\n")
    for _, rec in iter_records(path):
        t, msg, ts = rec.get("type"), rec.get("message", {}), short_ts(rec.get("timestamp"))
        if t == "user" and is_typed_prompt(rec):
            print(f"\n[{ts}] 🧑 USER\n{text_of(msg)}\n")
        elif t == "assistant":
            txt = text_of(msg)
            if txt:
                print(f"[{ts}] 🤖 ASSISTANT\n{txt}\n")
            if a.tools:
                for b in blocks(msg):
                    if b.get("type") == "tool_use":
                        inp = json.dumps(b.get("input", {}))[:160]
                        print(f"    ⚙ {b.get('name')}({inp})")
            if a.thinking:
                for b in blocks(msg):
                    if b.get("type") == "thinking":
                        print(f"    💭 {b.get('thinking', '')[:300]}")


# --------------------------------------------------------------------------- #
# permission outcomes (auto-mode classifier denials, human rejections, guards)
# --------------------------------------------------------------------------- #
# Sentinels that identify each is_error tool_result. Auto-approvals leave NO
# record (silent), so denials are the only observable permission signal — and
# a classifier-escalated-but-human-approved call is indistinguishable from a
# silent auto-approve. Denials, however, are fully captured on both paths.
CLASSIFIER_SENTINEL = "denied by the Claude Code auto mode classifier"
USER_REJECT_SENTINELS = ("The user doesn't want to proceed with this tool use",
                         "User rejected tool use")
GUARD_OPEN = "<tool_use_error>"
# pull "[Category] rest…" out of "Reason: [Category] rest…. If you have other"
_REASON_RE = re.compile(r"Reason:\s*(.*?)(?:\.\s+If you have other tasks|\Z)", re.S)
_CATEGORY_RE = re.compile(r"^\[([^\]]+)\]")


def _tool_result_text(block):
    """Decode a tool_result block's content (string OR list-of-text-blocks)."""
    c = block.get("content")
    if isinstance(c, str):
        return c
    if isinstance(c, list):
        return "\n".join(b.get("text", "") for b in c
                         if isinstance(b, dict) and b.get("type") == "text")
    return ""


def _classify_error(text):
    """Bucket an is_error tool_result into a permission/failure category."""
    if CLASSIFIER_SENTINEL in text:
        return "classifier-denied"
    if any(s in text for s in USER_REJECT_SENTINELS):
        return "user-rejected"
    if text.lstrip().startswith(GUARD_OPEN):
        return "tool-guard"
    return "exec-failure"


def _reason_category(text):
    """Extract the classifier's [Category] tag and short reason, if any.

    The [Category] prefix is stripped from the returned reason — it's printed
    separately on the label line, so keeping it here would double-print it.
    """
    m = _REASON_RE.search(text)
    reason = (m.group(1).strip() if m else "").replace("\n", " ")
    cm = _CATEGORY_RE.match(reason)
    cat = None
    if cm:
        cat = cm.group(1)
        reason = reason[cm.end():].lstrip()  # drop "[Category] " prefix
    if reason in ("", "No reason provided"):
        reason = "No reason provided"
    return cat, reason[:160]


def _label(tool, inp):
    """One-line 'Tool: subject' for a blocked tool call."""
    if not isinstance(inp, dict):
        return tool
    if tool == "Bash":
        line = (inp.get("command") or "").lstrip()
        line = re.sub(r"^(cd [^&|;]+&&|[A-Z_][A-Z0-9_]*=\S+|sudo|timeout \S+)\s+",
                      "", line.split("\n")[0]).lstrip()
        return f"Bash: {line[:100]}" if line else "Bash"
    subj = inp.get("file_path") or inp.get("path") or inp.get("pattern") or ""
    return f"{tool}: {subj}"[:120] if subj else tool


def _scan_permissions(path):
    """One pass over a transcript → (modes, [event, …]).

    event = {cat, tool, label, category, reason, ts}. tool_use always precedes
    its result in the append-only log, so the id→call map is built inline.
    """
    modes, calls, events = [], {}, []
    for _, rec in iter_records(path):
        t = rec.get("type")
        pm = rec.get("permissionMode")
        if pm and (not modes or modes[-1] != pm):
            modes.append(pm)
        if t == "assistant":
            for b in blocks(rec.get("message", {})):
                if b.get("type") == "tool_use":
                    calls[b.get("id")] = (b.get("name", "?"), b.get("input", {}))
        elif t == "user":
            for b in blocks(rec.get("message", {})):
                if b.get("type") != "tool_result" or not b.get("is_error"):
                    continue
                text = _tool_result_text(b)
                cat = _classify_error(text)
                tool, inp = calls.get(b.get("tool_use_id"), ("?", {}))
                rcat, reason = (_reason_category(text)
                                if cat == "classifier-denied" else (None, ""))
                events.append({"cat": cat, "tool": tool, "label": _label(tool, inp),
                               "category": rcat, "reason": reason,
                               "ts": short_ts(rec.get("timestamp"))})
    return modes, events


ORDER = ["classifier-denied", "user-rejected", "tool-guard", "exec-failure"]


def cmd_permissions(a):
    from collections import Counter
    sessions, agg = [], Counter()
    cat_tags, blocked_tools = Counter(), Counter()
    for path, slug, sid, _ in session_files(a.days, a.project, archive_root(a)):
        if a.session and not sid.startswith(a.session):
            continue
        modes, events = _scan_permissions(path)
        # AskUserQuestion "rejections" are the user dismissing a question popup,
        # not a permission denial — drop by default (--include-asks to keep).
        if not a.include_asks:
            events = [e for e in events
                      if not (e["cat"] == "user-rejected" and e["tool"] == "AskUserQuestion")]
        # Count everything (incl. exec-failures) toward the rollup so the summary
        # line is always accurate; exec-failures are only *itemized* per session
        # when --failures is set (they're tool errors, not blocks).
        agg.update(Counter(e["cat"] for e in events))
        for e in events:
            if e["cat"] == "classifier-denied":
                cat_tags[e["category"] or "(no category)"] += 1
            if e["cat"] != "exec-failure":
                blocked_tools[e["tool"]] += 1
        shown = events if a.failures else [e for e in events if e["cat"] != "exec-failure"]
        if not shown and not a.session:
            continue
        sessions.append({"project": short_slug(slug), "id": sid[:8],
                         "modes": modes or ["unknown"],
                         "counts": dict(Counter(e["cat"] for e in shown)),
                         "events": shown})

    if a.json:
        print(json.dumps({"sessions": sessions,
                          "rollup": {"by_category": dict(agg),
                                     "classifier_reason_tags": dict(cat_tags),
                                     "blocked_tools": dict(blocked_tools)}},
                         indent=2))
        return

    for s in sessions:
        print(f"\n=== {s['project']:<18.18}  {s['id']} ===  mode: {'→'.join(s['modes'])}")
        for cat in ORDER:
            evs = [e for e in s["events"] if e["cat"] == cat]
            if not evs:
                continue
            print(f"  {cat:<18} {len(evs)}")
            for e in evs[:12]:
                tag = f"[{e['category'] or '—'}] " if cat == "classifier-denied" else ""
                print(f"    {tag}{e['label']}")
                if cat == "classifier-denied" and e["reason"] != "No reason provided":
                    print(f"        ↳ {e['reason']}")
            if len(evs) > 12:
                print(f"    … +{len(evs) - 12} more")
    # rollup
    total = sum(v for k, v in agg.items() if k != "exec-failure")
    print(f"\n=== rollup ({len(sessions)} session(s)) ===")
    print(f"blocked total: {total}")
    for cat in ORDER:
        if cat == "exec-failure":
            continue
        if agg.get(cat):
            print(f"  {cat:<18} {agg[cat]}")
    if cat_tags:
        print("top classifier reason categories:")
        for tag, c in cat_tags.most_common(10):
            print(f"  {c:>4}  {tag}")
    if blocked_tools:
        print("top blocked tools:")
        for tool, c in blocked_tools.most_common(10):
            print(f"  {c:>4}  {tool}")
    if agg.get("exec-failure"):
        print(f"exec-failures (ran, non-zero): {agg['exec-failure']}"
              + ("" if a.failures else "   [--failures to itemize]"))


def cmd_tools(a):
    from collections import Counter
    tools, cmds = Counter(), Counter()
    for path, _, _, _ in session_files(a.days, a.project, archive_root(a)):
        for _, rec in iter_records(path):
            if rec.get("type") != "assistant":
                continue
            for b in blocks(rec.get("message", {})):
                if b.get("type") != "tool_use":
                    continue
                name = b.get("name", "?")
                tools[name] += 1
                if name == "Bash":
                    line = (b.get("input", {}).get("command") or "").lstrip()
                    line = re.sub(r"^(cd [^&|;]+&&|[A-Z_][A-Z0-9_]*=\S+|sudo|timeout \S+)\s+", "",
                                  line.split("\n")[0]).lstrip()
                    toks = line.split()
                    if toks:
                        cmds[" ".join(toks[:2])] += 1
    top = a.top
    print(f"=== tool usage (top {top}) ===")
    for name, c in tools.most_common(top):
        print(f"  {c:>5}  {name}")
    print(f"\n=== bash commands (top {top}) ===")
    for cmd, c in cmds.most_common(top):
        print(f"  {c:>5}  {cmd}")


# --------------------------------------------------------------------------- #
def main():
    p = argparse.ArgumentParser(prog="sessions", description=__doc__.splitlines()[0])
    sub = p.add_subparsers(dest="cmd", required=True)

    def add_archive(sp):
        sp.add_argument("--archive-dir", help="also search this archive dir "
                        "(default ~/claude-archives, set by session-archiver; "
                        "or $SESSIONS_ARCHIVE_DIR)")
        sp.add_argument("--no-archive", action="store_true",
                        help="search only the live ~/.claude dir, not the archive")

    def common(sp):
        sp.add_argument("--days", type=int, help="only sessions modified in the last N days")
        sp.add_argument("--project", help="filter to project slugs containing this substring")
        add_archive(sp)

    sp = sub.add_parser("ls", help="list sessions (date, id, project, msg count, opening prompt)")
    common(sp); sp.add_argument("--limit", type=int); sp.add_argument("--json", action="store_true")
    sp.set_defaults(fn=cmd_ls)

    sp = sub.add_parser("prompts", help="list your typed prompts per session")
    common(sp); sp.add_argument("--grep", help="only prompts matching this regex")
    sp.add_argument("--session", help="limit to a session-id prefix")
    sp.set_defaults(fn=cmd_prompts)

    sp = sub.add_parser("grep", help="search decoded message text (skips tool noise)")
    sp.add_argument("pattern"); common(sp)
    sp.add_argument("--role", choices=["user", "assistant", "both", "hook"], default="both",
                    help="user/assistant/both (default) search decoded message text; "
                         "'hook' opts into PostToolUse hook output / harness attachments "
                         "(type==attachment), excluded from the default search")
    sp.set_defaults(fn=cmd_grep)

    sp = sub.add_parser("show", help="render one session readable")
    sp.add_argument("session", help="session-id prefix")
    sp.add_argument("--tools", action="store_true", help="include tool calls")
    sp.add_argument("--thinking", action="store_true", help="include thinking blocks")
    add_archive(sp)
    sp.set_defaults(fn=cmd_show)

    sp = sub.add_parser("tools", help="normalized tool + bash command frequency")
    common(sp); sp.add_argument("--top", type=int, default=25)
    sp.set_defaults(fn=cmd_tools)

    sp = sub.add_parser("permissions", help="permission denials: auto-mode "
                        "classifier vs human rejections vs tool guards, per session + rollup")
    common(sp)
    sp.add_argument("--session", help="limit to a session-id prefix")
    sp.add_argument("--failures", action="store_true",
                    help="also itemize exec-failures (tools that ran and errored, not blocked)")
    sp.add_argument("--include-asks", action="store_true",
                    help="keep AskUserQuestion dismissals (excluded by default — not real denials)")
    sp.add_argument("--json", action="store_true")
    sp.set_defaults(fn=cmd_permissions)

    a = p.parse_args()
    try:
        a.fn(a)
    except BrokenPipeError:
        try:
            sys.stdout.close()
        except Exception:
            pass


if __name__ == "__main__":
    main()
