{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/session-setup.sh\"",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/swift-format.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/swift-test.sh\"",
            "timeout": 300,
            "statusMessage": "Running swift test on modified packages..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/swift-lint.sh\"",
            "timeout": 120,
            "statusMessage": "Running swiftlint..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/swift-test.sh\"",
            "timeout": 300,
            "statusMessage": "Running swift test on modified packages..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/swift-lint.sh\"",
            "timeout": 120,
            "statusMessage": "Running swiftlint..."
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/swift-test.sh\"",
            "timeout": 300,
            "statusMessage": "Running swift test on modified packages..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/swift-lint.sh\"",
            "timeout": 120,
            "statusMessage": "Running swiftlint..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/swift-test.sh\"",
            "timeout": 300,
            "statusMessage": "Running swift test on modified packages..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/swift-lint.sh\"",
            "timeout": 120,
            "statusMessage": "Running swiftlint..."
          }
        ]
      }
    ]
  }
}
