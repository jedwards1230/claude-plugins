#!/usr/bin/env bash
# Harbor CLI wrapper for registry.lilbro.cloud
# Usage: harbor <command> [args...]
#
# Commands:
#   status                              Show Harbor health and system info
#   project ls                          List all projects
#   project get <name>                  Show project details
#   project create-proxy <name> <url>   Create a proxy cache project
#   project delete <name>               Delete a project
#   registry ls                         List registry endpoints
#   registry get <id>                   Show registry endpoint details
#   registry create <name> <url>        Create a registry endpoint
#   registry delete <id>                Delete a registry endpoint
#
# Auth uses Basic auth via 1Password credentials (username + password).
# Set HARBOR_USER and HARBOR_PASS env vars to skip 1Password lookup.

set -euo pipefail

HARBOR_URL="https://registry.lilbro.cloud/api/v2.0"
CURL_OPTS=(-sS)
if [[ "${HARBOR_INSECURE_TLS:-}" == "1" ]]; then
  CURL_OPTS+=(-k)
fi

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# --- Dependency checks ---

for dep in curl jq op column; do
  if ! command -v "$dep" &>/dev/null; then
    echo -e "${RED}Error: '$dep' is required but not found in PATH.${RESET}" >&2
    exit 1
  fi
done

# --- Auth ---

get_credentials() {
  if [[ -n "${HARBOR_USER:-}" && -n "${HARBOR_PASS:-}" ]]; then
    return
  fi
  HARBOR_USER=$(op read "op://homelab/Harbor Registry/username" 2>/dev/null) || {
    echo -e "${RED}Error: Failed to read Harbor username from 1Password.${RESET}" >&2
    echo "Make sure you're signed in: op signin" >&2
    exit 1
  }
  export HARBOR_USER
  HARBOR_PASS=$(op read "op://homelab/Harbor Registry/password" 2>/dev/null) || {
    echo -e "${RED}Error: Failed to read Harbor credentials from 1Password.${RESET}" >&2
    echo "Make sure you're signed in: op signin" >&2
    exit 1
  }
  export HARBOR_PASS
}

# --- HTTP helpers ---

harbor_get() {
  local path="$1"
  get_credentials
  local http_code body
  body=$(curl "${CURL_OPTS[@]}" -w '\n%{http_code}' \
    --config <(printf 'user = "%s:%s"\n' "$HARBOR_USER" "$HARBOR_PASS") \
    -H "Accept: application/json" \
    "${HARBOR_URL}${path}")
  http_code=$(echo "$body" | tail -1)
  body=$(echo "$body" | sed '$d')
  if [[ "$http_code" -lt 200 || "$http_code" -ge 300 ]]; then
    echo -e "${RED}Error: HTTP ${http_code} on GET ${path}${RESET}" >&2
    echo "$body" | jq -r '.errors[]?.message // .' 2>/dev/null >&2 || echo "$body" >&2
    return 1
  fi
  echo "$body"
}

harbor_post() {
  local path="$1"
  local data="$2"
  get_credentials
  local http_code body
  body=$(curl "${CURL_OPTS[@]}" -w '\n%{http_code}' \
    -X POST \
    --config <(printf 'user = "%s:%s"\n' "$HARBOR_USER" "$HARBOR_PASS") \
    -H "Content-Type: application/json" \
    -H "Accept: application/json" \
    -d "$data" \
    "${HARBOR_URL}${path}")
  http_code=$(echo "$body" | tail -1)
  body=$(echo "$body" | sed '$d')
  if [[ "$http_code" -lt 200 || "$http_code" -ge 300 ]]; then
    echo -e "${RED}Error: HTTP ${http_code} on POST ${path}${RESET}" >&2
    echo "$body" | jq -r '.errors[]?.message // .' 2>/dev/null >&2 || echo "$body" >&2
    return 1
  fi
  echo "$body"
}

harbor_delete() {
  local path="$1"
  get_credentials
  local http_code body
  body=$(curl "${CURL_OPTS[@]}" -w '\n%{http_code}' \
    -X DELETE \
    --config <(printf 'user = "%s:%s"\n' "$HARBOR_USER" "$HARBOR_PASS") \
    -H "Accept: application/json" \
    "${HARBOR_URL}${path}")
  http_code=$(echo "$body" | tail -1)
  body=$(echo "$body" | sed '$d')
  if [[ "$http_code" -lt 200 || "$http_code" -ge 300 ]]; then
    echo -e "${RED}Error: HTTP ${http_code} on DELETE ${path}${RESET}" >&2
    echo "$body" | jq -r '.errors[]?.message // .' 2>/dev/null >&2 || echo "$body" >&2
    return 1
  fi
  echo "$body"
}

# --- Helpers ---

# URL-encode a string for safe interpolation into URL paths/query params
uriencode() {
  jq -rn --arg v "$1" '$v | @uri'
}

# Validate that a value is a positive integer (no path traversal)
validate_numeric_id() {
  local val="$1"
  local label="${2:-ID}"
  if ! [[ "$val" =~ ^[0-9]+$ ]]; then
    echo -e "${RED}Error: ${label} must be a positive integer, got '${val}'${RESET}" >&2
    return 1
  fi
}

# --- Commands ---

cmd_status() {
  echo -e "${BOLD}Harbor Status${RESET}"
  echo

  # Health
  echo -e "${BOLD}Component Health:${RESET}"
  local health
  health=$(harbor_get "/health") || return 1
  echo "$health" | jq -r '.components[] | "\(.name): \(.status)"' | while IFS=: read -r name status; do
    status=$(echo "$status" | xargs)
    if [[ "$status" == "healthy" ]]; then
      echo -e "  ${GREEN}[OK]${RESET} ${name}"
    else
      echo -e "  ${RED}[!!]${RESET} ${name}: ${status}"
    fi
  done

  local overall
  overall=$(echo "$health" | jq -r '.status')
  echo
  if [[ "$overall" == "healthy" ]]; then
    echo -e "  Overall: ${GREEN}${overall}${RESET}"
  else
    echo -e "  Overall: ${RED}${overall}${RESET}"
  fi

  # System info
  echo
  echo -e "${BOLD}System Info:${RESET}"
  local sysinfo
  sysinfo=$(harbor_get "/systeminfo") || return 1
  echo "$sysinfo" | jq -r '
    "  Version:        \(.harbor_version // "unknown")",
    "  Registry URL:   \(.registry_url // "unknown")",
    "  Auth Mode:      \(.auth_mode // "unknown")",
    "  Project Limit:  \(.project_creation_restriction // "unknown")",
    "  Self Register:  \(.self_registration // false)"
  '
}

cmd_project_ls() {
  echo -e "${BOLD}Projects:${RESET}"
  echo
  local projects
  projects=$(harbor_get "/projects?page_size=100") || return 1
  echo "$projects" | jq -r '
    ["NAME","TYPE","REPOS","PUBLIC","PROXY CACHE"],
    (.[] | [
      .name,
      (if .registry_id and .registry_id > 0 then "proxy" else "local" end),
      (.repo_count // 0 | tostring),
      (if .metadata.public == "true" then "yes" else "no" end),
      (if .registry_id and .registry_id > 0 then "registry_id=\(.registry_id)" else "-" end)
    ]) | @tsv
  ' | column -t -s$'\t'
}

cmd_project_get() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo -e "${RED}Error: project name required${RESET}" >&2
    echo "Usage: harbor project get <name>" >&2
    return 1
  fi

  local project encoded_name
  encoded_name=$(uriencode "$name")
  project=$(harbor_get "/projects?name=${encoded_name}&page_size=1") || return 1

  local count
  count=$(echo "$project" | jq 'length')
  if [[ "$count" -eq 0 ]]; then
    echo -e "${RED}Error: project '${name}' not found${RESET}" >&2
    return 1
  fi

  echo -e "${BOLD}Project: ${name}${RESET}"
  echo
  echo "$project" | jq -r '.[0] |
    "  ID:             \(.project_id)",
    "  Name:           \(.name)",
    "  Public:         \(.metadata.public // "false")",
    "  Repo Count:     \(.repo_count // 0)",
    "  Creation Time:  \(.creation_time)",
    "  Registry ID:    \(.registry_id // "none")"
  '

  # If proxy cache, show the registry endpoint
  local registry_id
  registry_id=$(echo "$project" | jq -r '.[0].registry_id // 0')
  if [[ "$registry_id" != "0" && "$registry_id" != "null" ]]; then
    echo
    echo -e "  ${CYAN}Proxy Cache Registry:${RESET}"
    local reg
    reg=$(harbor_get "/registries/${registry_id}") || return 1
    echo "$reg" | jq -r '
      "    Name:   \(.name)",
      "    Type:   \(.type)",
      "    URL:    \(.url)",
      "    Status: \(.status // "unknown")"
    '
  fi
}

cmd_project_create_proxy() {
  local name="${1:-}"
  local upstream_url="${2:-}"
  if [[ -z "$name" || -z "$upstream_url" ]]; then
    echo -e "${RED}Error: name and upstream URL required${RESET}" >&2
    echo "Usage: harbor project create-proxy <name> <upstream-url>" >&2
    echo "  Note: A registry endpoint for the upstream must exist first." >&2
    echo "  Use 'harbor registry ls' to find the registry_id, or create one with 'harbor registry create'." >&2
    return 1
  fi

  # Look up registry by URL
  local registries registry_id
  registries=$(harbor_get "/registries?page_size=100") || return 1
  registry_id=$(echo "$registries" | jq -r --arg url "$upstream_url" '
    [.[] | select(.url == $url)] | first | .id // empty
  ')

  if [[ -z "$registry_id" ]]; then
    echo -e "${RED}Error: No registry endpoint found for URL '${upstream_url}'${RESET}" >&2
    echo "Create one first: harbor registry create <name> <url>" >&2
    return 1
  fi

  echo -e "Creating proxy cache project '${name}' -> ${upstream_url} (registry_id=${registry_id})..."

  local payload
  payload=$(jq -n \
    --arg name "$name" \
    --argjson rid "$registry_id" \
    '{
      project_name: $name,
      metadata: { public: "true" },
      registry_id: $rid
    }')

  harbor_post "/projects" "$payload" >/dev/null || return 1
  echo -e "${GREEN}Project '${name}' created as proxy cache.${RESET}"
}

cmd_project_delete() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    echo -e "${RED}Error: project name required${RESET}" >&2
    echo "Usage: harbor project delete <name>" >&2
    return 1
  fi

  echo -e "${YELLOW}Delete project '${name}'? This cannot be undone.${RESET}"
  read -rp "Type the project name to confirm: " confirm
  if [[ "$confirm" != "$name" ]]; then
    echo "Aborted."
    return 1
  fi

  local encoded_name
  encoded_name=$(uriencode "$name")
  harbor_delete "/projects/${encoded_name}" >/dev/null || return 1
  echo -e "${GREEN}Project '${name}' deleted.${RESET}"
}

cmd_registry_ls() {
  echo -e "${BOLD}Registry Endpoints:${RESET}"
  echo
  local registries
  registries=$(harbor_get "/registries") || return 1

  local count
  count=$(echo "$registries" | jq 'length')
  if [[ "$count" -eq 0 ]]; then
    echo "  (none)"
    return
  fi

  echo "$registries" | jq -r '
    ["ID","NAME","TYPE","URL","STATUS"],
    (.[] | [
      (.id | tostring),
      .name,
      .type,
      .url,
      (.status // "unknown")
    ]) | @tsv
  ' | column -t -s$'\t'
}

cmd_registry_create() {
  local name="${1:-}"
  local url="${2:-}"
  if [[ -z "$name" || -z "$url" ]]; then
    echo -e "${RED}Error: name and URL required${RESET}" >&2
    echo "Usage: harbor registry create <name> <url>" >&2
    echo "  Examples:" >&2
    echo "    harbor registry create docker-hub https://hub.docker.com" >&2
    echo "    harbor registry create ghcr https://ghcr.io" >&2
    return 1
  fi

  # Auto-detect type from URL
  local reg_type="docker-registry"
  case "$url" in
    *hub.docker.com*|*docker.io*) reg_type="docker-hub" ;;
    *ghcr.io*) reg_type="github-ghcr" ;;
    *gcr.io*) reg_type="google-gcr" ;;
    *quay.io*) reg_type="quay" ;;
    *ecr.amazonaws.com*) reg_type="aws-ecr" ;;
  esac

  echo -e "Creating registry endpoint '${name}' (${reg_type}) -> ${url}..."

  local payload
  payload=$(jq -n \
    --arg name "$name" \
    --arg type "$reg_type" \
    --arg url "$url" \
    '{
      name: $name,
      type: $type,
      url: $url,
      insecure: false
    }')

  harbor_post "/registries" "$payload" >/dev/null || return 1
  echo -e "${GREEN}Registry endpoint '${name}' created (type: ${reg_type}).${RESET}"
}

cmd_registry_get() {
  local id="${1:-}"
  if [[ -z "$id" ]]; then
    echo -e "${RED}Error: registry ID required${RESET}" >&2
    echo "Usage: harbor registry get <id>" >&2
    return 1
  fi
  validate_numeric_id "$id" "registry ID" || return 1

  local reg
  reg=$(harbor_get "/registries/${id}") || return 1

  echo -e "${BOLD}Registry Endpoint:${RESET}"
  echo
  echo "$reg" | jq -r '
    "  ID:          \(.id)",
    "  Name:        \(.name)",
    "  Type:        \(.type)",
    "  URL:         \(.url)",
    "  Status:      \(.status // "unknown")",
    "  Insecure:    \(.insecure // false)",
    "  Description: \(.description // "-")",
    "  Created:     \(.creation_time)"
  '
}

cmd_registry_delete() {
  local id="${1:-}"
  if [[ -z "$id" ]]; then
    echo -e "${RED}Error: registry ID required${RESET}" >&2
    echo "Usage: harbor registry delete <id>" >&2
    return 1
  fi
  validate_numeric_id "$id" "registry ID" || return 1

  echo -e "${YELLOW}Delete registry endpoint ID ${id}?${RESET}"
  read -rp "Confirm (y/N): " confirm
  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "Aborted."
    return 1
  fi

  harbor_delete "/registries/${id}" >/dev/null || return 1
  echo -e "${GREEN}Registry endpoint ${id} deleted.${RESET}"
}

cmd_help() {
  echo -e "${BOLD}harbor${RESET} - CLI wrapper for Harbor registry at registry.lilbro.cloud"
  echo
  echo -e "${BOLD}Usage:${RESET}"
  echo "  harbor <command> [args...]"
  echo
  echo -e "${BOLD}Commands:${RESET}"
  echo "  status                              Show Harbor health and system info"
  echo "  project ls                          List all projects"
  echo "  project get <name>                  Show project details"
  echo "  project create-proxy <name> <url>   Create a proxy cache project"
  echo "  project delete <name>               Delete a project (with confirmation)"
  echo "  registry ls                         List configured registry endpoints"
  echo "  registry get <id>                   Show registry endpoint details"
  echo "  registry create <name> <url>        Create a registry endpoint"
  echo "  registry delete <id>                Delete a registry endpoint"
  echo "  help                                Show this help"
  echo
  echo -e "${BOLD}Auth:${RESET}"
  echo "  Credentials are fetched from 1Password (op://homelab/Harbor Registry)."
  echo "  Set HARBOR_USER and HARBOR_PASS env vars to skip 1Password lookup."
}

# --- Main ---

cmd="${1:-help}"
shift || true

case "$cmd" in
  status)
    cmd_status
    ;;
  project)
    subcmd="${1:-}"
    shift || true
    case "$subcmd" in
      ls|list) cmd_project_ls ;;
      get) cmd_project_get "$@" ;;
      create-proxy) cmd_project_create_proxy "$@" ;;
      delete) cmd_project_delete "$@" ;;
      *)
        echo -e "${RED}Error: unknown project subcommand '${subcmd}'${RESET}" >&2
        echo "Usage: harbor project {ls|get|create-proxy|delete}" >&2
        exit 1
        ;;
    esac
    ;;
  registry)
    subcmd="${1:-}"
    shift || true
    case "$subcmd" in
      ls|list) cmd_registry_ls ;;
      get) cmd_registry_get "$@" ;;
      create) cmd_registry_create "$@" ;;
      delete) cmd_registry_delete "$@" ;;
      *)
        echo -e "${RED}Error: unknown registry subcommand '${subcmd}'${RESET}" >&2
        echo "Usage: harbor registry {ls|get|create|delete}" >&2
        exit 1
        ;;
    esac
    ;;
  help|--help|-h)
    cmd_help
    ;;
  *)
    echo -e "${RED}Error: unknown command '${cmd}'${RESET}" >&2
    cmd_help >&2
    exit 1
    ;;
esac
